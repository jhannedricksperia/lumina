<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/b_background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/maroonDark"
        app:navigationIcon="@drawable/ic_back"
        app:title="Profile"
        app:titleTextColor="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <!-- Avatar -->
            <FrameLayout
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tv_initials"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/circle_maroon"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="34sp"
                    android:fontFamily="@font/poppins_bold"
                    android:text="\?\?" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_profile_photo"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/circle_maroon"
                    android:visibility="gone"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlayLuminaCircle" />
            </FrameLayout>

            <!-- Full Name -->
            <TextView
                android:id="@+id/tv_full_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:gravity="center"
                android:layout_marginBottom="6dp"
                android:text="Full Name" />

            <!-- Designation / Role -->
            <TextView
                android:id="@+id/tv_designation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_active"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginBottom="16dp"
                android:text="Designation" />

            <!-- Divider -->
            <View
                android:layout_width="60dp"
                android:layout_height="1dp"
                android:background="@color/yellowDark"
                android:layout_marginBottom="16dp" />

            <!-- Date Joined -->
            <TextView
                android:id="@+id/tv_date_joined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:textColor="#88FFFFFF"
                android:textSize="12sp"
                android:gravity="center"
                android:text="Joined —" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>

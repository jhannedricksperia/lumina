<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Title -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginBottom="12dp"
        android:hint="Title *">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Description -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginBottom="12dp"
        android:hint="Description">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:maxLines="6" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Location -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginBottom="12dp"
        android:hint="📍 Location">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_where"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Date + Time pickers -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <!-- Date -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="6dp">
            <Button
                android:id="@+id/btn_pick_date"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:text="📅 Pick Date"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/tv_picked_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:textColor="#AAFFFFFF"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="2dp"
                android:text="No date selected" />
        </LinearLayout>

        <!-- Time -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="6dp">
            <Button
                android:id="@+id/btn_pick_time"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:text="🕐 Pick Time"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/tv_picked_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:textColor="#AAFFFFFF"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="2dp"
                android:text="No time selected" />
        </LinearLayout>
    </LinearLayout>

    <!-- Max Participants -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginBottom="12dp"
        android:hint="Max Participants (0 = unlimited)">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_max_participants"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:maxLines="1"
            android:text="0" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Audience -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_bold"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"
        android:text="Audience" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tv_audience_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/poppins"
            android:textColor="#AAFFFFFF"
            android:textSize="12sp"
            android:text="👥 Everyone" />

        <TextView
            android:id="@+id/btn_pick_audience"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/glass_card"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:fontFamily="@font/poppins_bold"
            android:textColor="@color/yellowDark"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true"
            android:text="Change" />
    </LinearLayout>

    <!-- Image hint -->
    <TextView
        android:id="@+id/tv_image_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins"
        android:text="No image selected"
        android:textColor="#88FFFFFF"
        android:textSize="11sp"
        android:layout_marginBottom="6dp" />

    <!-- Image pick button -->
    <TextView
        android:id="@+id/btn_pick_image"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/glass_card"
        android:gravity="center"
        android:text="📷  Add Image (optional)"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="8dp" />

    <!-- Image preview -->
    <ImageView
        android:id="@+id/iv_preview"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:scaleType="centerCrop"
        android:background="@drawable/glass_card"
        android:visibility="gone" />

</LinearLayout>
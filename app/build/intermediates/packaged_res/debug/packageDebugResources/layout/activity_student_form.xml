<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/b_background"
    android:orientation="vertical">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/maroonDark"
        app:navigationIcon="@drawable/back"
        app:navigationIconTint="@color/white"
        app:title="Add Student"
        app:titleTextColor="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Glass card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_card"
                android:elevation="8dp"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="@font/poppins_bold"
                    android:text="Student Information"
                    android:textColor="@color/white"
                    android:textSize="15sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    android:gravity="center_horizontal">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_profile_photo"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:background="@drawable/avatar_circle"
                        android:clickable="true"
                        android:focusable="true"
                        android:scaleType="centerCrop"
                        android:src="@drawable/profile_pic"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlayLuminaCircle" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tv_change_picture"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="18dp"
                    android:fontFamily="@font/poppins_bold"
                    android:text="Change picture"
                    android:textColor="@color/yellow"
                    android:textSize="12sp" />

                <!-- Info banner -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_info_banner"
                    android:fontFamily="@font/poppins"
                    android:padding="10dp"
                    android:text="Username and password are generated automatically and emailed to the student."
                    android:textColor="#7B4F00"
                    android:textSize="11sp" />

                <!-- First Name -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_first_name"
                    style="@style/LuminaField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:hint="First Name">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_first_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:inputType="textPersonName"
                        android:textColor="@color/white"
                        android:textColorHint="@color/textHint" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Last Name -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_last_name"
                    style="@style/LuminaField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:hint="Last Name">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_last_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:inputType="textPersonName"
                        android:textColor="@color/white"
                        android:textColorHint="@color/textHint" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Email -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_email"
                    style="@style/LuminaField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:hint="BulSU Email Address"
                    app:helperText="\@ms.bulsu.edu.ph only"
                    app:helperTextTextColor="@color/textMuted">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/white"
                        android:textColorHint="@color/textHint" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- ══════════════════════════════════════════════════════════
                     CAMPUS
                     The loading row uses layout_height="0dp" when gone so it
                     contributes zero pixels — no phantom gaps.
                ══════════════════════════════════════════════════════════ -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_campus"
                    style="@style/LuminaField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Campus"
                    app:endIconMode="dropdown_menu">

                    <AutoCompleteTextView
                        android:id="@+id/acv_campus"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:focusable="false"
                        android:fontFamily="@font/poppins"
                        android:inputType="none"
                        android:paddingStart="12dp"
                        android:textColor="@color/white"
                        android:textColorHint="@color/textHint" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Loading hint sits flush below the field; height collapses when gone -->
                <LinearLayout
                    android:id="@+id/ll_campus_loading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">
                    <ProgressBar
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="6dp"
                        android:indeterminateTint="@color/yellow" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="Loading campuses…"
                        android:textColor="#55FFFFFF"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- ══════════════════════════════════════════════════════════
                     COLLEGE — 14dp gap from Campus (same as other fields)
                ══════════════════════════════════════════════════════════ -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_college"
                    style="@style/LuminaField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="College"
                    android:enabled="false"
                    app:endIconMode="dropdown_menu">

                    <AutoCompleteTextView
                        android:id="@+id/acv_college"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:focusable="false"
                        android:fontFamily="@font/poppins"
                        android:inputType="none"
                        android:paddingStart="12dp"
                        android:textColor="@color/white"
                        android:textColorHint="@color/textHint" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:id="@+id/ll_college_loading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">
                    <ProgressBar
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="6dp"
                        android:indeterminateTint="@color/yellow" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="Loading colleges…"
                        android:textColor="#55FFFFFF"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- ══════════════════════════════════════════════════════════
                     COURSE — 14dp gap from College (same as other fields)
                ══════════════════════════════════════════════════════════ -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_course"
                    style="@style/LuminaField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Course"
                    android:enabled="false"
                    app:endIconMode="dropdown_menu">

                    <AutoCompleteTextView
                        android:id="@+id/acv_course"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:focusable="false"
                        android:fontFamily="@font/poppins"
                        android:inputType="none"
                        android:paddingStart="12dp"
                        android:textColor="@color/white"
                        android:textColorHint="@color/textHint" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:id="@+id/ll_course_loading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">
                    <ProgressBar
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="6dp"
                        android:indeterminateTint="@color/yellow" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="Loading courses…"
                        android:textColor="#55FFFFFF"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- Error -->
                <TextView
                    android:id="@+id/tv_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/poppins"
                    android:gravity="center"
                    android:textColor="#FF6B6B"
                    android:textSize="11sp"
                    android:visibility="gone" />

                <!-- Progress -->
                <ProgressBar
                    android:id="@+id/progress_bar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:indeterminateTint="@color/yellow"
                    android:visibility="gone" />

                <!-- Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_cancel"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/poppins_bold"
                        android:text="CANCEL"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        app:cornerRadius="12dp"
                        app:strokeColor="#44FFFFFF" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_register"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="2"
                        android:fontFamily="@font/poppins_bold"
                        android:text="REGISTER"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        app:backgroundTint="@color/maroon"
                        app:cornerRadius="12dp"
                        app:elevation="6dp" />

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
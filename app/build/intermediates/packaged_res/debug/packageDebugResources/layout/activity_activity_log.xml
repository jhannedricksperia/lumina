<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/b_background"
    android:orientation="vertical">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/maroonDark"
        app:navigationIcon="@drawable/back"
        app:navigationIconTint="@color/white"
        app:titleTextColor="@color/white" />

    <!-- Search + Export row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/maroonDark"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_search"
            style="@style/LuminaField"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:hint="Search by email, subject, module...">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:textColor="@color/white"
                android:textColorHint="@color/textHint"
                android:textSize="12sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <ImageButton
            android:id="@+id/btn_search"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Search"
            android:padding="8dp"
            android:src="@drawable/search"
            app:tint="@color/yellow" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_export_pdf"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:fontFamily="@font/poppins_bold"
            android:text="Export"
            android:textColor="@color/maroonDark"
            android:textSize="11sp"
            app:backgroundTint="@color/yellow"
            app:cornerRadius="8dp"
            app:icon="@drawable/download"
            app:iconTint="@color/maroonDark" />

    </LinearLayout>

    <!-- Module filter chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_module"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_module_all"
                style="@style/LuminaChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="All" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_module_student"
                style="@style/LuminaChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Student" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_module_staff"
                style="@style/LuminaChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Staff" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_module_campus"
                style="@style/LuminaChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Campus" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_module_college"
                style="@style/LuminaChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="College" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_module_course"
                style="@style/LuminaChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Course" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_module_announcement"
                style="@style/LuminaChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Announcement" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_module_event"
                style="@style/LuminaChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_module_reports"
                style="@style/LuminaChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reports" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Action filter chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_action_all"
                style="@style/LuminaChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="All Actions" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_action_create"
                style="@style/LuminaChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_action_modified"
                style="@style/LuminaChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Modified" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_action_delete"
                style="@style/LuminaChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Delete" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_action_viewed"
                style="@style/LuminaChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Viewed" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Count -->
    <TextView
        android:id="@+id/tv_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins"
        android:paddingHorizontal="16dp"
        android:paddingBottom="6dp"
        android:text="Loading..."
        android:textColor="#55FFFFFF"
        android:textSize="11sp" />

    <!-- Log list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_logs"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="8dp" />

</LinearLayout>

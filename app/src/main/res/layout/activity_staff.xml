<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/b_background">

    <FrameLayout
        android:id="@+id/staff_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:background="@color/maroonDark"
        android:elevation="8dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/nav_dashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_dashboard" app:tint="@color/nav_tab_selector" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Dashboard" android:textSize="9sp"
                android:fontFamily="@font/poppins" android:textColor="@color/nav_tab_selector" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_post"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_post" app:tint="@color/nav_tab_selector" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Post" android:textSize="10sp"
                android:fontFamily="@font/poppins" android:textColor="@color/nav_tab_selector" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_notifications"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_notification" app:tint="@color/nav_tab_selector" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="Notifications"
                android:textColor="@color/nav_tab_selector"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_profile" app:tint="@color/nav_tab_selector" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Profile" android:textSize="10sp"
                android:fontFamily="@font/poppins" android:textColor="@color/nav_tab_selector" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>

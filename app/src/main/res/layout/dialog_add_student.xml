<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_add_student.xml
    Fields: First Name, Last Name, Email (@ms.bulsu.edu.ph enforced),
            Campus, College, Course.
    Username = email prefix (auto)  |  Password = random alphanumeric (auto)
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Info banner: auto-generated fields -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_info_banner"
            android:fontFamily="@font/poppins"
            android:padding="10dp"
            android:text="Username and password are generated automatically and emailed to the student."
            android:textColor="#7B4F00"
            android:textSize="11sp" />

        <!-- First Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_first_name"
            style="@style/LuminaField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="First Name">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_first_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:inputType="textPersonName"
                android:textSize="13sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Last Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_last_name"
            style="@style/LuminaField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Last Name">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_last_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:inputType="textPersonName"
                android:textSize="13sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Email (domain-restricted) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_email"
            style="@style/LuminaField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:hint="Email">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:inputType="textEmailAddress"
                android:textSize="13sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="4dp"
            android:fontFamily="@font/poppins"
            android:text="Must end with @ms.bulsu.edu.ph"
            android:textColor="#55FFFFFF"
            android:textSize="10sp" />

        <!-- Campus -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_campus"
            style="@style/LuminaField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Campus">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_campus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:inputType="textCapWords"
                android:textSize="13sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- College -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_college"
            style="@style/LuminaField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="College">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_college"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:inputType="textCapWords"
                android:textSize="13sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Course -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_course"
            style="@style/LuminaField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:hint="Course">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_course"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:inputType="textCapWords"
                android:textSize="13sp" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</ScrollView>
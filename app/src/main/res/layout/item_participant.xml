<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:background="@drawable/glass_card">

        <!-- Avatar -->
        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/avatar_circle"
            android:layout_marginEnd="12dp">
            <TextView
                android:id="@+id/tv_initials"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:text="AB" />
        </FrameLayout>

        <!-- Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_full_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:text="Full Name" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="4dp">
                <TextView android:id="@+id/tv_campus" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:fontFamily="@font/poppins" android:textColor="#88FFFFFF"
                    android:textSize="10sp" android:text="Campus" />
                <TextView android:id="@+id/tv_college" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:fontFamily="@font/poppins" android:textColor="#88FFFFFF"
                    android:textSize="10sp" android:text="College" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="2dp">
                <TextView android:id="@+id/tv_course" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:fontFamily="@font/poppins" android:textColor="#88FFFFFF"
                    android:textSize="10sp" android:text="Course" />
                <TextView android:id="@+id/tv_date_joined" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:fontFamily="@font/poppins" android:textColor="@color/yellow"
                    android:textSize="10sp" android:gravity="end" android:text="—" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/b_background"
    android:orientation="vertical">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/maroonDark"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="50dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_greeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:text="Hello, Staff!" />
                <TextView
                    android:id="@+id/tv_today_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:textColor="#88FFFFFF"
                    android:textSize="11sp"
                    android:text="Monday, January 1, 2025" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_filter_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:textColor="#88FFFFFF"
                android:textSize="11sp"
                android:text="Today" />
        </LinearLayout>

        <!-- Filter Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginTop="10dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_today"
                    style="@style/LuminaChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Today" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_week"
                    style="@style/LuminaChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This Week" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_month"
                    style="@style/LuminaChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This Month" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_custom"
                    style="@style/LuminaChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Date" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── My Posts Stat Cards ── -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:columnCount="2"
                android:useDefaultMargins="true">

                <!-- Announcements Posted -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/glass_card"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="Announcements"
                        android:textColor="#88FFFFFF"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/tv_announcement_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_bold"
                        android:text="0"
                        android:textColor="@color/yellowDark"
                        android:textSize="28sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="Posted by me"
                        android:textColor="@color/gray"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- Events Posted -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/glass_card"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="Events"
                        android:textColor="#88FFFFFF"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/tv_event_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_bold"
                        android:text="0"
                        android:textColor="@color/yellowDark"
                        android:textSize="28sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="Posted by me"
                        android:textColor="@color/gray"
                        android:textSize="10sp" />
                </LinearLayout>

            </GridLayout>

            <!-- ── Interaction Stat Cards ── -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:columnCount="3"
                android:useDefaultMargins="true">

                <!-- Total Likes -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/glass_card"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="♥ Likes"
                        android:textColor="#EF9A9A"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/tv_total_likes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_bold"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="24sp" />
                </LinearLayout>

                <!-- Total Comments -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/glass_card"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="💬 Comments"
                        android:textColor="#90CAF9"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/tv_total_comments"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_bold"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="24sp" />
                </LinearLayout>

                <!-- Total Event Goers -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/glass_card"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="🎫 Goers"
                        android:textColor="#A5D6A7"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/tv_total_goers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_bold"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="24sp" />
                </LinearLayout>

            </GridLayout>

            <!-- ── Line Chart: My Posts Last 7 Days ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="@font/poppins_bold"
                    android:text="My Posts — Last 7 Days"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chart_my_posts"
                    android:layout_width="match_parent"
                    android:layout_height="180dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>

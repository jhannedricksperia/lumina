<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Luminae" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/maroon</item>
        <item name="colorPrimaryVariant">@color/maroonDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/yellow</item>
        <item name="colorOnSecondary">@color/bgBlack</item>
        <item name="android:windowBackground">@color/bgBlack</item>
        <item name="android:statusBarColor">@color/maroonDeep</item>
        <item name="colorControlNormal">@color/textMuted</item>
        <item name="colorControlActivated">@color/yellow</item>
        <item name="android:textColorHint">@color/textHint</item>
        <item name="toolbarStyle">@style/LuminaToolbar</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.Luminae.MaterialAlertDialog</item>
        <item name="android:alertDialogTheme">@style/ThemeOverlay.Luminae.AppCompatAlertDialog</item>
    </style>

    <style name="ThemeOverlay.Luminae.MaterialAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/bgBlack</item>
        <item name="android:colorBackground">@color/bgBlack</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorPrimary">@color/yellow</item>
        <item name="colorOnPrimary">@color/bgBlack</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.Luminae.AlertDialog.Button.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.Luminae.AlertDialog.Button.Negative</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.Luminae.AlertDialog.Button.Negative</item>
        <!-- Fix black EditText fields inside dialogs -->
        <item name="editTextStyle">@style/LuminaEditText</item>
        <item name="textInputStyle">@style/LuminaField</item>
    </style>

    <style name="Widget.Luminae.AlertDialog.Button.Positive" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/yellow</item>
        <item name="rippleColor">#40F2C94C</item>
    </style>

    <style name="Widget.Luminae.AlertDialog.Button.Negative" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/white</item>
        <item name="rippleColor">#33FFFFFF</item>
    </style>

    <style name="ThemeOverlay.Luminae.AppCompatAlertDialog" parent="ThemeOverlay.AppCompat.Dialog.Alert">
        <item name="colorPrimary">@color/yellow</item>
        <item name="colorAccent">@color/yellow</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/white</item>
        <item name="android:colorBackground">@color/bgBlack</item>
    </style>

    <!-- Reusable style for all text input fields with rounded corners -->
    <style name="LuminaField" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">#33FFFFFF</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxBackgroundColor">#0DFFFFFF</item>
        <item name="hintTextColor">#80FFFFFF</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="startIconMinSize">24dp</item>
        <item name="editTextStyle">@style/LuminaEditText</item>
    </style>

    <!-- EditText inside LuminaField — transparent bg, white text -->
    <style name="LuminaEditText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorHint">@color/textHint</item>
    </style>

    <style name="LuminaChip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="android:textColor">@color/chip_text_selector</item>
        <item name="chipBackgroundColor">@color/chip_bg_selector</item>
        <item name="chipStrokeColor">@color/chip_stroke_selector</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textSize">11sp</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="chipMinHeight">32dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="android:layout_marginEnd">8dp</item>
    </style>

    <style name="LuminaToolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:paddingTop">25dp</item>
    </style>

    <style name="ShapeAppearanceOverlayLuminaCircle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="ShapeAppearanceOverlayLuminaRoundedCard">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

</resources>
<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:label="LUMINA"
        android:icon="@drawable/logo"
        android:roundIcon="@drawable/logo"
        android:theme="@style/Theme.Luminae"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".activities.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".activities.ForgotPasswordActivity"
            android:exported="false" />
        <activity
            android:name=".activities.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".activities.AdminActivity"
            android:exported="false" />
        <activity
            android:name=".activities.CampusManagementActivity"
            android:exported="false" />
        <activity
        android:name=".activities.CollegeManagementActivity"
        android:exported="false" />
        <activity
            android:name=".activities.CourseManagementActivity"
            android:exported="false" />
        <activity
            android:name=".activities.CampusFormActivity"
            android:exported="false" />
        <activity
            android:name=".activities.CollegeFormActivity"
            android:exported="false" />
        <activity
            android:name=".activities.CourseFormActivity"
            android:exported="false" />
        <activity
            android:name=".activities.EventParticipantsActivity"
            android:exported="false" />
        <activity
            android:name=".activities.StaffFormActivity"
            android:exported="false" />
        <activity
            android:name=".activities.StaffManagementActivity"
            android:exported="false" />
        <activity
            android:name=".activities.StudentManagementActivity"
            android:exported="false" />
        <activity
            android:name=".activities.ActivityLogActivity"
            android:exported="false" />
        <activity
            android:name=".activities.StudentActivity"
            android:exported="false" />
        <activity
            android:name=".activities.StaffActivity"
            android:exported="false" />
        <activity
            android:name=".activities.PostDetailActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />
        <activity
            android:name=".activities.UserProfileActivity"
            android:exported="false" />
        <activity
            android:name=".activities.StudentFormActivity"
            android:exported="false" />
        <activity
            android:name=".activities.AnnouncementFormActivity"
            android:exported="false" />
        <activity
            android:name=".activities.EventFormActivity"
            android:exported="false" />
        <activity
            android:name=".activities.ConfigurationsActivity"
            android:exported="false" />

        <service
            android:name=".notifications.LuminaFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="lumina_push" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />
    </application>

</manifest>